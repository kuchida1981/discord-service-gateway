# Discord Settings
DISCORD_PUBLIC_KEY=your_public_key_here
DISCORD_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
DISCORD_GUILD_ID=your_guild_id_here

# ngrok Settings (required for Docker Compose development environment)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=your_ngrok_domain_here

# n8n Settings
N8N_HEALTH_URL=https://n8n.u-rei.com/healthz
N8N_TASKS_LIST_URL=https://your-n8n-url/webhook/tasks-list

# GCP Settings（dev.sh で使用）
GCP_PROJECT_ID=kuchida-devel
GCP_REGION=asia-northeast1
GCP_SERVICE_NAME=discord-gateway
